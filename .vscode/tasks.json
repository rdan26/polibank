{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe compilar proyecto modular",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe", 
            "args": [
                "-g",
                "${workspaceFolder}\\src\\*.c",
                "-o",
                "${workspaceFolder}\\polibank.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compila todos los archivos .c en la carpeta src"
        }
    ]
}