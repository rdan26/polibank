# ------------------------------------
# Polibank C Project .gitignore
# ------------------------------------

# 1. Compiled Executables
*.exe
*.out
*.app

# 2. Compiled Object Files (The intermediate steps of compiling)
*.o
*.obj

# 3. Compiled Libraries (If you ever build dynamic/static libraries)
*.dll
*.so
*.dylib
*.a
*.lib

# 4. Debugging and Crash Logs
*.log
*.crash
*.dmp

# 5. OS Junk Files (Windows and Mac hidden files)
Thumbs.db
Desktop.ini
.DS_Store

# 6. Archivos de base de datos local y temporales
*.bin
*.dat
proyecto_total.txt
estado_cuenta_0650105547.txt
balances_cuentas.csv
log_boveda.txt
ranking_saldos.txt
codigo_completo_utf8.txt